# PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/naze_calendar?schema=public"

# NextAuth / Auth.js
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-long-random-string"
